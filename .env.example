APP_NAME="Health Drive"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=America/Sao_Paulo
APP_LOCALE=pt_BR

# ── Banco de dados ────────────────────────────────────────────
# Desenvolvimento: sqlite
# Staging/Produção: mysql ou pgsql
DB_CONNECTION=sqlite
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=healthdrive
# DB_USERNAME=root
# DB_PASSWORD=

# ── Cache ─────────────────────────────────────────────────────
# Desenvolvimento: file | Produção: redis
CACHE_STORE=file
# CACHE_STORE=redis

# ── Filas ─────────────────────────────────────────────────────
# Desenvolvimento: sync | Produção: redis
QUEUE_CONNECTION=sync
# QUEUE_CONNECTION=redis

# ── Redis ─────────────────────────────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ── Sessão ────────────────────────────────────────────────────
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false

# ── Logging ───────────────────────────────────────────────────
# Desenvolvimento: daily | Produção: stack (daily + slack)
LOG_CHANNEL=daily
LOG_LEVEL=debug
# LOG_LEVEL=error
LOG_DEPRECATIONS_CHANNEL=null
LOG_SLACK_WEBHOOK_URL=

# ── Autenticação Sanctum ──────────────────────────────────────
# Expiração do token em minutos (480 = 8 horas)
SANCTUM_TOKEN_EXPIRATION=480

# ── CORS ──────────────────────────────────────────────────────
# Desenvolvimento: * (aberto) | Produção: URL do frontend
CORS_ALLOWED_ORIGINS=*
# CORS_ALLOWED_ORIGINS=https://app.healthdrive.com.br

# ── Rate Limiting ─────────────────────────────────────────────
API_RATE_LIMIT=60

# ── E-mail ────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@healthdrive.com.br"
MAIL_FROM_NAME="${APP_NAME}"

# ── Broadcast ─────────────────────────────────────────────────
BROADCAST_CONNECTION=log

# ── Filesystem ────────────────────────────────────────────────
FILESYSTEM_DISK=local

# ── Vite (não utilizado neste projeto API-only) ───────────────
VITE_APP_NAME="${APP_NAME}"
